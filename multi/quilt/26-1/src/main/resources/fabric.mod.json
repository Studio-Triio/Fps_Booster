{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "Client-side FPS optimizations.",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "default",
        "value": "com.fpsbooster.FpsBoosterFabric"
      }
    ]
  },
  "mixins": [
    { "config": "fpsbooster.mixins.json", "environment": "client" }
  ],
  "depends": {
    "fabricloader": ">=0.18.0",
    "minecraft": "${minecraft_version}"
  }
}
